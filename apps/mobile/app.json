{
  "expo": {
    "name": "CycleWays",
    "slug": "cycleways-mobile",
    "scheme": "cycleways",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "locales": {
      "he": "./locales/he.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.cycleways.mobile",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true,
        "NSLocationWhenInUseUsageDescription": "Show your current location on the map while planning and following rides, and keep turn-by-turn guidance running during a ride.",
        "UIBackgroundModes": [
          "location",
          "audio"
        ],
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "waze",
          "moovit"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "cycleways",
              "app.cycleways.mobile"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "app.cycleways.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#ededed",
          "imageWidth": 180,
          "resizeMode": "contain",
          "ios": {
            "image": "./assets/splash-screen-ios.png",
            "backgroundColor": "#ededed",
            "resizeMode": "contain",
            "enableFullScreenImage_legacy": true
          }
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Show your current location on the map while planning and following rides, and keep turn-by-turn guidance running during a ride.",
          "locationAlwaysAndWhenInUsePermission": false,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      "./plugins/withMetroBundleURLFallback.js",
      "./plugins/withWebroot.js"
    ]
  }
}
